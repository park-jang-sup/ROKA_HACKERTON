rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /weapons/{weaponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /detectionRecords/{recordId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}